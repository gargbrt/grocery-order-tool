# Same Postgres connection as the main app's .env (same value, same Supabase
# project) - this server reads/writes the same Store/Order/CatalogItem tables.
DATABASE_URL="postgresql://postgres.<your-project-ref>:<your-db-password>@aws-0-<your-region>.pooler.supabase.com:6543/postgres"

# "stdio" for local/CLI testing (default), "http" when deploying for Claude to connect to
TRANSPORT="stdio"

# Only used when TRANSPORT=http
PORT="3000"
