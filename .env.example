# PostgreSQL connection string. A real Supabase project was already created
# during testing: "grocery-order-tool", ref ohebfdpyuumoqbqmnjxj, region ap-south-1.
# Get your DB password from: Supabase Dashboard -> this project -> Settings -> Database
# -> "Reset database password" if you don't have it (it's not retrievable after creation).
# Then use the pooled connection string shown there, e.g.:
DATABASE_URL="postgresql://postgres.ohebfdpyuumoqbqmnjxj:[YOUR-PASSWORD]@aws-0-ap-south-1.pooler.supabase.com:6543/postgres"

# Any long random string — used to sign login sessions
JWT_SECRET="replace-with-a-long-random-string"

# Public URL of your deployment, e.g. https://your-store.vercel.app
# Needed to register the Telegram webhook.
PUBLIC_BASE_URL="http://localhost:3000"
