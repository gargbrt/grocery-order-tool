# PostgreSQL connection string. Create your own free Supabase project at
# https://supabase.com/dashboard -> New project, then go to
# Settings -> Database -> "Connection string" (pooled/transaction mode) and
# fill in the password you set when creating the project. It looks like:
DATABASE_URL="postgresql://postgres.<your-project-ref>:<your-db-password>@aws-0-<your-region>.pooler.supabase.com:6543/postgres"

# Any long random string — used to sign login sessions
JWT_SECRET="replace-with-a-long-random-string"

# Public URL of your deployment, e.g. https://your-store.vercel.app
# Needed to register the Telegram webhook.
PUBLIC_BASE_URL="http://localhost:3000"
